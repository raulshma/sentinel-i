NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

POSTGRES_DB=sentinel_i
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel_i

VALKEY_URL=redis://localhost:6379

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
AI_PROVIDER=openrouter
GEOCODE_API_KEY=
GEOCODE_BASE_URL=https://geocode.maps.co

CRAWL4AI_PORT=11235
# API on host: http://localhost:11235/crawl | API in Docker: http://crawl4ai:11235/crawl
CRAWL4AI_API_URL=http://localhost:11235/crawl
CRAWL4AI_API_KEY=

RSS_FEED_URLS=
RSS_SYNC_CRON=*/15 * * * *
HTTP_FETCH_TIMEOUT_MS=10000
CRAWL4AI_TIMEOUT_MS=15000

DEV_TOOLS=false
